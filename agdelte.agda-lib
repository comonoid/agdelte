name: agdelte
include:
  src
depend:
  standard-library
  -- agdelte-store is consumed by the server/ APP layer (CrmServer + tests), built
  -- with explicit `-i src -i server`; src/ itself imports no Agdelte.Storage.*.
  -- (agdelte-payments removed: nothing here imports it — only agdelte-courses does,
  -- and that lib declares the dep itself.)
  agdelte-store
