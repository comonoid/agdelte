name: agdelte
include:
  src
depend:
  standard-library
  -- agdelte-store is consumed by the server/ APP layer (CrmServer + tests), built
  -- with explicit `-i src -i server`; src/ itself imports no Agdelte.Storage.*.
  -- (agdelte-payments is not depended on here: the framework imports none of it —
  -- the consuming domains, e.g. agdelte-pack-psych, declare that dep themselves.)
  agdelte-store
